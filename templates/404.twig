{% extends 'layouts/base.twig' %}

{% block content %}
    <div class="container-element">
        {% app_block 'error_404_before' %}
        <h1>{{ 'error.404_title' | trans }}</h1>
        <p>{{ 'error.404_message' | trans }}</p>
        <a href="/">{{ 'error.return_home' | trans }}</a>
        {% app_block 'error_404_after' %}
    </div>
{% endblock %}
